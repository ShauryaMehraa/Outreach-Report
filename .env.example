==============================
CORE API KEYS
==============================
HuggingFace (required)
Used for: pyannote diarization model (gated) + model downloads

HF_TOKEN=your_huggingface_token_here

==============================
LLM MODEL PATH (optional)
==============================
Path to the locally cached Mistral-7B-Instruct-v0.3 snapshot.
Defaults to the JupyterHub shared cache location below.
Override this on your own machine if the model is stored elsewhere.

LLM_MODEL_PATH=/models/huggingface/models--mistralai--Mistral-7B-Instruct-v0.3/snapshots/c170c708c41dac9275d15a8fff4eca08d52bab71

==============================
ZOHO WORKDRIVE (if pulling audio from cloud)
==============================

ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_WORKDRIVE_FOLDER_ID=your_folder_id # folder containing audio files
